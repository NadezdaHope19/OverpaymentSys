@startuml
skinparam { 
     backgroundColor #2C3E50
     arrowColor #ECF0F1
     actorbordercolor #FFDB8B
     actorBackgroundColor #3498DB
     rectangleBorderColor #FFDB8B
     shadowing true
     roundcorner 10
}

rectangle block1 [
     Надежда
     <size:10><color:#666666>логика</color></size>
]

rectangle "Руслан" as block2
rectangle block3 [
     Юля
     <size:10><color:#666666>красота</color></size>
]

block1 <-[#3498DB]-> block2
block2 ..> block3
block3 <|-- block1

actor "Пользователь1" as user1
actor "Пользователь2" as user2
rectangle "СФР" {
     rectangle "ЮрОтдел" as moduleA
     rectangle "УСОСД" as moduleB
     database "Base" as db
     cloud "данные" as cl
     folder "папка" as fl
     file "файл" as fi
     storage "храм" as XR
     queue "очередь" as och
}

user1 --> moduleA
moduleA --> moduleB
moduleB --> db
db --> moduleA
moduleA --> user1
boundary "кружок" as bd
person "сущность" as ag
rectangle "база данных" <<database>> as db2 #lightblue

@enduml
